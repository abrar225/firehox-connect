{
  "name": "firehox-connect",
  "private": true,
  "scripts": {
    "dev:frontend": "pnpm --filter frontend dev",
    "dev:signaling": "pnpm --filter signaling-server dev",
    "dev": "pnpm run dev:frontend & pnpm run dev:signaling",
    "build": "pnpm --filter database generate && pnpm -r build",
    "lint": "pnpm -r lint",
    "format": "prettier --write \"**/*.{ts,tsx,js,jsx,json,md}\"",
    "format:check": "prettier --check \"**/*.{ts,tsx,js,jsx,json,md}\"",
    "typecheck": "pnpm -r exec tsc --noEmit"
  },
  "devDependencies": {
    "eslint": "8.57.0",
    "prettier": "3.2.5",
    "prisma": "5.13.0",
    "puppeteer": "^24.39.0",
    "socket.io-client": "4.7.5",
    "typescript": "5.4.5"
  },
  "engines": {
    "node": ">=20.11.1",
    "pnpm": ">=9.1.0"
  },
  "packageManager": "pnpm@9.1.0",
  "dependencies": {
    "@prisma/client": "5.13.0",
    "next": "14.2.35"
  }
}
